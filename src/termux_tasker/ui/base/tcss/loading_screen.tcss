LoadingScreen {
    align: center middle;
}

#loading_dialog {
    width: 90%;
    height: 60%;
    border: tall $primary;
    background: $surface;
    padding: 2;
    align: center middle;
}

LoadingIndicator {
    height: auto;
}

#loading_message {
    margin-top: 1;
    height: 1fr;
    width: 100%;
    content-align: center middle;
    text-align: center;
}
