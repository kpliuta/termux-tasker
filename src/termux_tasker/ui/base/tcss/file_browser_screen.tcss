FileBrowserScreen {
    align: center middle;
}

FileBrowserScreen Grid {
    width: 90%;
    height: 90%;
    grid-size: 2;
    grid-rows: 1fr 3;
    border: tall $primary;
    background: $surface;
    padding: 0 1;
}

FileBrowserScreen Grid DirectoryTree {
    column-span: 2;
    margin-bottom: 1;
}

FileBrowserScreen Grid Button {
    width: 1fr;
    margin: 0 1;
}

